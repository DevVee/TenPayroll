# Copy this file to .env and fill in your Supabase credentials.
# To transfer to a new project: update only these two lines.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# PIN / RFID hashing salt — generate once with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ⚠ Set this BEFORE any employee saves a PIN. Never change it after.
# Must match HASH_SALT in kiosk/.env exactly.
VITE_HASH_SALT=your-random-salt-here
