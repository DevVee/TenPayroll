# Kiosk build-time environment variables
# Copy this file to .env and fill in your values.
# These are injected at build time via electron-vite's define block.
# The built binary never reads .env directly — values are baked in.

# Your Supabase project URL (found in: Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (found in: Settings → API → Project API keys → anon/public)
# This key is safe to embed in the kiosk binary — Supabase RLS protects the data.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
